# Database Credentials
MONGO_INITDB_ROOT_USERNAME=YOUR_MONGO_USERNAME_HERE
MONGO_INITDB_ROOT_PASSWORD=YOUR_MONGO_PASSWORD_HERE
MONGODB_URI=mongodb://YOUR_MONGO_USERNAME_HERE:YOUR_MONGO_PASSWORD_HERE@mongo:27017/boss478?authSource=admin

# Admin Credentials
ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD_HERE
ADMIN_TOKEN_SECRET=YOUR_ADMIN_TOKEN_SECRET_HERE

# Private Section Credentials
PRIVATE_PASSWORD=YOUR_PRIVATE_PASSWORD_HERE
PRIVATE_TOKEN_SECRET=YOUR_PRIVATE_TOKEN_SECRET_HERE

# Legacy env vars (fallback — migrate to PRIVATE_*)
# STOCK_PASSWORD=YOUR_STOCK_PASSWORD_HERE
# STOCK_TOKEN_SECRET=YOUR_STOCK_TOKEN_SECRET_HERE

# Mongo Express
MONGO_EXPRESS_USERNAME=YOUR_MONGO_EXPRESS_USERNAME_HERE
MONGO_EXPRESS_PASSWORD=YOUR_MONGO_EXPRESS_PASSWORD_HERE
MONGO_EXPRESS_URL=http://localhost:8081

# ─── Docker Dev ─────────────────────────────────────────────────
# For `docker compose --profile dev up -d --build`:
# MONGODB_URI must use the Docker service name "mongo" (not localhost)
# The default value below already uses "mongo:27017" — it works for Docker dev too.
