{
  "name": "boss478",
  "version": "1.10.8",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -p 3300",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "analyze": "ANALYZE=true npm run build",
    "seed": "npx tsx scripts/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "exifr": "^7.1.3",
    "heic-convert": "^2.1.0",
    "heic2any": "^0.0.4",
    "html-to-image": "^1.11.13",
    "isomorphic-dompurify": "^3.0.0",
    "mongoose": "^9.1.6",
    "next": "^16.2.2",
    "postcss": "^8.5.6",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-image-crop": "^11.0.10",
    "sharp": "^0.34.5",
    "ua-parser-js": "^2.0.10",
    "uuid": "^13.0.0",
    "yahoo-finance2": "^3.14.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/archiver": "^7.0.0",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ua-parser-js": "^0.7.39",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
