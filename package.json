{
  "name": "boss478",
  "version": "1.10.54",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -p 3300",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "analyze": "ANALYZE=true npm run build",
    "seed": "npx tsx scripts/seed.ts",
    "seed-dictionary": "npx tsx scripts/seed-dictionary.ts",
    "parse-oxford": "npx tsx scripts/parse-oxford.ts",
    "enrich-stress": "npx tsx scripts/enrich-stress.ts",
    "enrich-definitions": "npx tsx scripts/enrich-definitions.ts",
    "assemble-words": "npx tsx scripts/assemble-words.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": ".agents/evals/run-evals.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "exifr": "^7.1.3",
    "heic-convert": "^2.1.0",
    "heic2any": "^0.0.4",
    "html-to-image": "^1.11.13",
    "isomorphic-dompurify": "^3.18.0",
    "mongoose": "^9.7.1",
    "next": "^16.2.9",
    "postcss": "^8.5.6",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-image-crop": "^11.1.2",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "yahoo-finance2": "^3.15.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/archiver": "^7.0.0",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
